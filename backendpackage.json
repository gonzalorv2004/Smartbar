const express = require("express");
const app = express();

app.get("/", (req, res) => {
  res.json({
    mensaje: "SmartBar funcionando 🚀",
    estado: "OK",
    servicio: "backend",
    autor: "Gonzalo Rubio"
  });
});

app.listen(3000, () => {
  console.log("Servidor en puerto 3000");
});

app.get("/health", (req, res) => {
  res.json({ status: "UP" });
});
